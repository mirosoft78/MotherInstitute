@using MotherInstitute.Models
@using Microsoft.AspNetCore.Http
@inject AppDbContext _context

@{
    var userType = Context.Session.GetString("UserType");
    var userName = Context.Session.GetString("UserName");

    var org = _context.Organization
        .OrderBy(x => x.SLNO)
        .FirstOrDefault();
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MotherInstitute</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet">

    <style>

            body {
                margin: 0;
                padding: 0;
                overflow-x: hidden;
                background: #eef2f7;
                font-family: 'Segoe UI', sans-serif;
            }

            /* =========================
                               TOPBAR
                    ========================== */

            .topbar {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                width: 100%;
                background: linear-gradient(90deg,#2c0f75,#c83c3c);
                z-index: 1000;
                padding: 12px 35px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            }

            .topbar-inner {
                display: flex;
                align-items: center;
                width: 100%;
            }

            .topbar-left {
                display: flex;
                align-items: center;
                gap: 15px;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                margin-left: auto;
            }

            .menu-btn {
                border: none;
                background: white;
                color: #222;
                font-size: 18px;
                border-radius: 6px;
                width: 42px;
                height: 42px;
                cursor: pointer;
            }

            .topbar-logo {
                width: 55px;
                height: 55px;
                background: white;
                border-radius: 50%;
                padding: 5px;
            }

            .topbar-home-link {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
            }

            .topbar h1 {
                color: white;
                margin: 0;
                font-size: 34px;
                font-weight: bold;
            }

            .topbar p {
                color: #dbeafe;
                margin: 0;
                font-size: 16px;
            }

            /* =========================
                             WEBSITE MENU
                    ========================== */

            .website-menu {
                display: flex;
                align-items: center;
                gap: 35px;
                margin-right: 35px;
            }

                .website-menu a {
                    color: white;
                    text-decoration: none;
                    font-size: 20px;
                    font-weight: 600;
                }

                    .website-menu a:hover {
                        color: #ffd54f;
                    }

            .logout-btn {
                background: #ff4b4b;
                color: white;
                padding: 10px 25px;
                border-radius: 25px;
                text-decoration: none;
                font-weight: bold;
                font-size: 18px;
            }

            .topbar-right span {
                color: white;
                font-size: 18px;
                margin-right: 20px;
            }

            /* =========================
                               CONTENT
                    ========================== */

            .content-wrapper {
                margin-top: 110px;
            }

            .page-body {
                padding: 20px;
            }

            /* =========================
                               SIDEBAR
                    ========================== */

            .sidebar-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.45);
                z-index: 1500;
                display: none;
            }

                .sidebar-overlay.show {
                    display: block;
                }

            .sidebar {
                position: fixed;
                top: 0;
                left: -290px;
                width: 280px;
                height: 100vh;
                background: linear-gradient(180deg,#2c0f75,#1d2c8f);
                z-index: 1600;
                transition: 0.3s ease;
                display: flex;
                flex-direction: column;
            }

                .sidebar.show {
                    left: 0;
                }

            .sidebar-header {
                text-align: center;
                padding: 18px;
                background: rgba(255,255,255,0.06);
                flex-shrink: 0;
            }

            .sidebar-logo {
                width: 75px;
                height: 75px;
                background: white;
                border-radius: 50%;
                padding: 6px;
            }

            .sidebar-header h2 {
                color: white;
                margin-top: 10px;
                font-size: 28px;
                font-weight: 700;
            }

            .sidebar-header p {
                color: #dbeafe;
                margin-bottom: 0;
            }

            .sidebar-menu {
                flex: 1;
                overflow-y: auto;
                padding-bottom: 20px;
            }

            .sidebar-link,
            .sidebar-dropdown-btn {
                display: flex;
                align-items: center;
                gap: 10px;
                width: 100%;
                padding: 14px 20px;
                background: transparent;
                border: none;
                color: white !important;
                text-decoration: none;
                font-size: 16px;
                cursor: pointer;
            }

                .sidebar-link:hover,
                .sidebar-dropdown-btn:hover {
                    background: rgba(255,255,255,0.12);
                }

            .sidebar-submenu {
                display: none;
                background: rgba(0,0,0,0.15);
            }

                .sidebar-submenu.show {
                    display: block;
                }

                .sidebar-submenu a {
                    display: block;
                    padding: 11px 20px 11px 42px;
                    color: white !important;
                    text-decoration: none;
                }

                    .sidebar-submenu a:hover {
                        background: rgba(255,255,255,0.10);
                    }

            .sidebar-footer {
                padding: 15px;
                border-top: 1px solid rgba(255,255,255,0.10);
                flex-shrink: 0;
            }

            .sidebar-logout {
                display: flex;
                align-items: center;
                gap: 10px;
                color: white !important;
                text-decoration: none;
                background: rgba(255,255,255,0.10);
                padding: 13px 16px;
                border-radius: 10px;
                font-weight: 600;
            }

                .sidebar-logout:hover {
                    background: #ff4b4b;
                }

            .mobile-menu-btn {
                display: none;
            }

            /* MOBILE HOME MENU */

            .mobile-home-overlay {
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.45);
                z-index: 2999;
                display: none;
            }

                .mobile-home-overlay.show {
                    display: block;
                }

            .mobile-home-menu {
                position: fixed;
                top: 0;
                left: -270px;
                width: 250px;
                height: 100vh;
                background: linear-gradient(180deg,#2c0f75,#c83c3c);
                z-index: 3000;
                transition: 0.3s;
                padding-top: 80px;
            }

                .mobile-home-menu.show {
                    left: 0;
                }

                .mobile-home-menu a {
                    display: block;
                    color: white;
                    text-decoration: none;
                    padding: 16px 24px;
                    font-size: 20px;
                    font-weight: 600;
                    border-bottom: 1px solid rgba(255,255,255,0.1);
                }

            @@media(max-width:1100px) {

                

                .mobile-menu-btn {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border: none;
                    background: white;
                    width: 50px;
                    height: 50px;
                    border-radius: 10px;
                    font-size: 28px;
                    font-weight: bold;
                    color: #222;
                    cursor: pointer;
                    margin-right: 10px;
                }

                .website-menu {
                    display: none;
                }

                .topbar h1 {
                    font-size: 24px;
                }

                .topbar p {
                    font-size: 13px;
                }
            }

    </style>

</head>

<body>
    @if (string.IsNullOrEmpty(userName))
    {
        <div class="mobile-home-overlay"
             id="mobileHomeOverlay"
             onclick="closeHomeMenu()"></div>

        <div class="mobile-home-menu"
             id="mobileHomeMenu">

            <a href="/">Home</a>

            <a href="/Home/About">About</a>

            <a href="/Home/Admission">Admission</a>

            <a href="/Home/StudentResult">Result</a>

            <a href="/Home/Gallery">Gallery</a>

            <a href="/Home/Contact">Contact</a>

        </div>
    }

    @if (!string.IsNullOrEmpty(userName))
    {
        <div class="sidebar-overlay"
             id="sidebarOverlay"
             onclick="closeSidebar()"></div>

        <div class="sidebar"
             id="sidebar">

            <div class="sidebar-header">

                <img src="~/images/logo.png"
                     class="sidebar-logo" />

                <h2>TMIS Portal</h2>

                <p>Navigation Menu</p>

            </div>

            <div class="sidebar-menu">

                @if (userType == "ADMIN")
                {
                    <a href="/Admin/Home"
                           class="sidebar-link">

                        <span>🏠 Home</span>

                    </a>

                    <a href="/Admin/User"
                           class="sidebar-link">

                        <span>👤 User</span>

                    </a>
                }
                else if (userType == "MARKETING")
                {
                    <a href="/Marketing/Home"
                           class="sidebar-link">

                        <span>🏠 Home</span>

                    </a>

                    <a href="/Marketing/MarketingPanel/ViewStudent"
                           class="sidebar-link">

                        <span>🎯 View Student</span>

                    </a>
                    <a href="/Marketing/MarketingPanel/ViewVisitStudent"
                           class="sidebar-link">

                        <i class="bi bi-people-fill"></i>

                        <span>Visit Student</span>

                    </a>
                    <a href="/Marketing/MarketingPanel/AgentWiseReport"
                           class="sidebar-link">

                        <span>📊 History Report</span>

                    </a>
                }
                else
                {
                    <a href="/Executive/Home"
                           class="sidebar-link">

                        <span>🏠 Home</span>

                    </a>

                    <!-- MASTER -->

                    <button type="button"
                            class="sidebar-dropdown-btn"
                            onclick="toggleSidebarMenu('masterSubmenu','masterArrow')">

                        <span>📂 Master</span>

                        <span id="masterArrow">⌄</span>

                    </button>

                    <div class="sidebar-submenu"
                         id="masterSubmenu">

                        <a href="/Executive/AcademicSession">
                            📅 Academic Session
                        </a>

                        <a href="/Executive/Organization">
                            🏢 Organization
                        </a>

                        <a href="/Executive/Subjects">
                            📚 Subjects
                        </a>

                        <a href="/Executive/BedDetails">
                            🛏️ Bed Details
                        </a>

                        <a href="/Executive/Course">
                            📘 Course
                        </a>

                        <a href="/Executive/Fees">
                            💰 Fees
                        </a>

                        <a href="/Executive/EizocMember">
                            📊 EIZOC Member
                        </a>

                    </div>

                    <!-- REGISTRATION -->

                    <button type="button"
                            class="sidebar-dropdown-btn"
                            onclick="toggleSidebarMenu('registrationSubmenu','registrationArrow')">

                        <span>📋 Registration</span>

                        <span id="registrationArrow">⌄</span>

                    </button>

                    <div class="sidebar-submenu"
                         id="registrationSubmenu">

                        <a href="/Executive/Registration">
                            ✏️ Registration
                        </a>

                        <a href="/Executive/ViewStudentsRegistration">
                            📄 View Students Registration
                        </a>

                        <a href="/Executive/EditStudentRegistration">
                            📝 Edit Student Registration
                        </a>

                        <a href="/Executive/StudentStatus">
                            📚 Student Status
                        </a>

                    </div>
                    <!-- ACCOUNTS -->

                    <button type="button"
                            class="sidebar-dropdown-btn"
                            onclick="toggleSidebarMenu('accountsSubmenu','accountsArrow')">

                        <span>💰 Accounts</span>

                        <span id="accountsArrow">⌄</span>

                    </button>

                    <div class="sidebar-submenu"
                         id="accountsSubmenu">

                        <a href="/Executive/StudentExpenses">
                            💸 Student Expenses
                        </a>

                        <a href="/Executive/StudentPayments">
                            💵 Student Payments
                        </a>

                    </div>
                    <!-- MARKETING -->

                    <button type="button"
                            class="sidebar-dropdown-btn"
                            onclick="toggleSidebarMenu('marketingSubmenu','marketingArrow')">

                        <span>📢 Marketing</span>

                        <span id="marketingArrow">⌄</span>

                    </button>

                    <div class="sidebar-submenu"
                         id="marketingSubmenu">

                        <a href="/Executive/SchoolMaster">
                            🏫 Manage School
                        </a>

                        <a href="/Executive/MarketingAgent">
                            🧑‍💼 Manage Agent
                        </a>

                        <a href="/Executive/MarketingStudent">
                            🎯 Manage Student
                        </a>
                        <a href="/Executive/ViewStudentVisit">
                            👁️ View Visit History
                        </a>

                        <a href="/Marketing/MarketingPanel/ViewStudent">
                            👁️ View Student 
                        </a>
                        <a href="/Executive/AgentVisitHistory">
                            👁️ Agent Visit History
                        </a>

                    </div>
                }

            </div>

            <div class="sidebar-footer">

                <a asp-controller="Login"
                       asp-action="Logout"
                       class="sidebar-logout">

                    <span>🚪</span>

                    <span>Logout</span>

                </a>

            </div>

        </div>
    }

    <div class="content-wrapper">

        <div class="topbar">

            <div class="topbar-inner">

                <div class="topbar-left">
                    @if (string.IsNullOrEmpty(userName))
                    {
                        <button type="button"
                                class="mobile-menu-btn"
                                onclick="openHomeMenu()">

                            ☰

                        </button>
                    }

                    @if (!string.IsNullOrEmpty(userName))
                    {
                        <button type="button"
                                class="menu-btn"
                                onclick="openSidebar()">

                            ☰

                        </button>
                    }

                    @if (userType == "ADMIN")
                    {
                        <a href="/Admin/Home"
                               class="topbar-home-link">
                            <img src="@(string.IsNullOrEmpty(org?.LOGO) ? "/images/logo.png" : org.LOGO)"
                                 class="topbar-logo" />

                            <div>
                                <h1>@(org?.NAME ?? "TMIS")TMIS</h1>
                                <p>Excellence in Science Education</p>
                            </div>
                        </a>
                    }
                    else if (userType == "EXECUTIVE")
                    {
                        <a href="/Executive/Home"
                               class="topbar-home-link">
                            <img src="@(string.IsNullOrEmpty(org?.LOGO) ? "/images/logo.png" : org.LOGO)"
                                 class="topbar-logo" />

                            <div>
                                <h1>@(org?.NAME ?? "TMIS")</h1>
                                <p>Excellence in Science Education</p>
                            </div>
                        </a>
                    }
                    else if (userType == "MARKETING")
                    {
                        <a href="/Marketing/Home"
                               class="topbar-home-link">
                            <img src="@(string.IsNullOrEmpty(org?.LOGO) ? "/images/logo.png" : org.LOGO)"
                                 class="topbar-logo" />

                            <div>
                                <h1>@(org?.NAME ?? "TMIS")</h1>
                                <p>Excellence in Science Education</p>
                            </div>
                        </a>
                    }
                    else
                    {
                        <a href="/Home"
                               class="topbar-home-link">
                            <img src="~/images/logo.png"
                                 class="topbar-logo" />

                            <div>
                                <h1>TMIS</h1>
                                <p>Excellence in Science Education</p>
                            </div>
                        </a>
                    }

                </div>

                <div class="topbar-right">

                    @if (string.IsNullOrEmpty(userName))
                    {
                        <div class="website-menu">

                            <a href="/">Home</a>

                            <a href="/Home/About">About</a>

                            <a href="/Home/Admission">Admission</a>

                            <a href="/Home/StudentResult">Result</a>

                            <a href="/Home/Gallery">Gallery</a>

                            <a href="/Home/Contact">Contact</a>

                        </div>

                        <a asp-controller="Login"
                               asp-action="Index"
                               class="logout-btn">

                            Login

                        </a>
                    }
                    else
                    {
                        <span>

                            @if (userType == "EXECUTIVE")
                            {
                                <text>
                                     Executive  - @userName
                                </text>
                            }
                            else if (userType == "MARKETING")
                            {
                                <text>
                                    Marketing  - @userName
                                </text>
                            }
                            else if (userType == "ADMIN")
                            {
                                <text>
                                    Admin  - @userName
                                </text>
                            }
                            else
                            {
                                <text>
                                    Welcome to TMIS Portal
                                </text>
                            }

                        </span>
                    }

                </div>

            </div>

        </div>

        @if (string.IsNullOrEmpty(userName))
        {
            <div style="margin:0; padding:0; width:100%;">

                @RenderBody()

            </div>
        }
        else
        {
            <div class="page-body">

                @RenderBody()

            </div>
        }

    </div>

    <script>

            function openSidebar() {

                document.getElementById("sidebar")
                    .classList.add("show");

                document.getElementById("sidebarOverlay")
                    .classList.add("show");
            }

            function closeSidebar() {

                document.getElementById("sidebar")
                    .classList.remove("show");

                document.getElementById("sidebarOverlay")
                    .classList.remove("show");
            }
            function openHomeMenu() {

                document.getElementById("mobileHomeMenu")
                    .classList.add("show");

                document.getElementById("mobileHomeOverlay")
                    .classList.add("show");
            }

            function closeHomeMenu() {

                document.getElementById("mobileHomeMenu")
                    .classList.remove("show");

                document.getElementById("mobileHomeOverlay")
                    .classList.remove("show");
            }
            function toggleSidebarMenu(menuId, arrowId) {

                var menu = document.getElementById(menuId);

                var arrow = document.getElementById(arrowId);

                menu.classList.toggle("show");

                arrow.innerText =
                    menu.classList.contains("show")
                        ? "⌃"
                        : "⌄";
            }

    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>