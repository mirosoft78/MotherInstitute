@model List<MotherInstitute.Models.Subjects>

<div class="main-content-box">

    <style>

            .page-header {
                padding: 8px 16px;
                border-radius: 10px;
                background: linear-gradient(90deg, #0b5ed7, #1ec8ff);
                margin-bottom: 10px;
            }

                .page-header h2 {
                    margin: 0;
                    font-size: 22px;
                    color: white;
                    text-align: center;
                    font-weight: 700;
                }

            .page-form-row {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 12px;
                flex-wrap: wrap;
            }

                .page-form-row label {
                    font-size: 13px;
                    font-weight: 600;
                    color: #374151;
                }

                .page-form-row input[type="text"] {
                    width: 220px;
                    height: 30px;
                    padding: 4px 8px;
                    border: 1px solid #d1d5db;
                    border-radius: 5px;
                    font-size: 12px;
                    outline: none;
                }

                .page-form-row button {
                    background: #2563eb;
                    color: white;
                    border: none;
                    padding: 5px 14px;
                    border-radius: 5px;
                    font-size: 12px;
                    font-weight: 600;
                    cursor: pointer;
                    height: 30px;
                }

                    .page-form-row button:hover {
                        background: #1d4ed8;
                    }

            .empty-field-warning {
                border: 1px solid red !important;
                box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.18) !important;
            }

            .subjects-table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 6px;
                background: white;
                border-radius: 8px;
                overflow: hidden;
            }

                .subjects-table thead tr {
                    background: #1e40af;
                }

                .subjects-table th {
                    color: white;
                    padding: 6px 8px;
                    text-align: center;
                    font-size: 12px;
                    font-weight: 700;
                    height: 30px;
                    border-right: 1px solid rgba(255,255,255,0.10);
                    white-space: nowrap;
                }

                .subjects-table td {
                    padding: 5px 8px;
                    border-bottom: 1px solid #e5e7eb;
                    vertical-align: middle;
                    font-size: 12px;
                    text-align: center;
                    height: 32px;
                    line-height: 1.1;
                    white-space: nowrap;
                }

                .subjects-table tbody tr:nth-child(even) {
                    background: #fafafa;
                }

                .subjects-table tbody tr:hover {
                    background: #edf4ff;
                }

            .action-icon {
                width: 18px;
                height: 18px;
                cursor: pointer;
            }

            .inline-edit-box {
                width: 140px;
                height: 24px;
                padding: 2px 5px;
                border: 1px solid #d1d5db;
                border-radius: 4px;
                font-size: 11px;
            }

    </style>

    <div class="page-header">
        <h2>Manage Subjects</h2>
    </div>

    <form asp-action="Create"
          method="post"
          class="page-form-row"
          id="subjectForm">

        <label>Subject Name</label>

        <div style="display:flex; flex-direction:column;">

            <input type="text"
                   name="NAME"
                   id="SUBJECT_NAME"
                   oninput="validateSubjectName(this)" />

            <span id="subjectNameError"
                  class="text-danger"
                  style="font-size:12px; margin-top:4px;">
            </span>

        </div>

        <button type="submit">
            Add
        </button>

    </form>

    <table class="subjects-table">

        <thead>
            <tr>
                <th>Edit</th>
                <th>Name</th>
                <th>Delete</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td style="text-align:center; white-space:nowrap;">

                        <img src="~/images/edit.png"
                             onclick="editRow(this)"
                             class="action-icon" />

                        <img src="~/images/update.png"
                             onclick="updateRow(this, '@item.SLNO')"
                             class="action-icon"
                             style="display:none;" />

                        <img src="~/images/cancel.png"
                             onclick="cancelEdit(this)"
                             class="action-icon"
                             style="display:none; margin-left:4px;" />

                    </td>

                    <td>

                        <span>@item.NAME</span>

                        <input type="text"
                               value="@item.NAME"
                               class="inline-edit-box"
                               style="display:none;" oninput="this.value=this.value.replace(/[^A-Za-z\s]/g,'');" />

                    </td>

                    <td style="text-align:center;">

                        <form asp-action="Delete"
                              asp-route-id="@item.SLNO"
                              method="post"
                              style="display:inline;"
                              onsubmit="return confirm('Are you sure you want to delete this subject?');">

                            <button type="submit"
                                    style="border:none; background:none;">

                                <img src="~/images/delete.png"
                                     class="action-icon" />

                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        var successMessage = '@TempData["SuccessMessage"]';
        var errorMessage = '@TempData["ErrorMessage"]';

        if (successMessage && successMessage !== '') {
            alert(successMessage);
        }

        if (errorMessage && errorMessage !== '') {
            alert(errorMessage);
        }

        var subjectForm = document.getElementById("subjectForm");
        var subjectName = document.getElementById("SUBJECT_NAME");

        if (subjectForm) {

            subjectForm.addEventListener("submit", function (e) {

                subjectName.classList.remove("empty-field-warning");

                if (subjectName.value.trim() === "") {

                    subjectName.classList.add("empty-field-warning");

                    if (!confirm("Subject Name is empty. Do you want to continue?")) {

                        e.preventDefault();
                    }
                }
            });
        }
    });
        function validateSubjectName(input) {

        var error = document.getElementById("subjectNameError");

        var originalValue = input.value;

        input.value = input.value.replace(/[^A-Za-z\s]/g, '');

        if (originalValue !== input.value) {

            error.innerHTML = "Only letters are allowed.";

        } else {

            error.innerHTML = "";
        }
    }

    function editRow(btn) {

        let row = btn.closest("tr");

        btn.style.display = "none";

        row.children[0].children[1].style.display = "inline";
        row.children[0].children[2].style.display = "inline";

        let span = row.children[1].children[0];
        let input = row.children[1].children[1];

        span.style.display = "none";
        input.style.display = "inline-block";
    }

    function cancelEdit(btn) {

        let row = btn.closest("tr");

        row.children[0].children[0].style.display = "inline";
        row.children[0].children[1].style.display = "none";
        row.children[0].children[2].style.display = "none";

        let span = row.children[1].children[0];
        let input = row.children[1].children[1];

        input.value = span.innerText;

        span.style.display = "inline";
        input.style.display = "none";
    }

    function updateRow(btn, id) {

        let row = btn.closest("tr");

        let nameInput = row.children[1].children[1];

        let name = nameInput.value;

        nameInput.classList.remove("empty-field-warning");

        if (name.trim() === "") {

            nameInput.classList.add("empty-field-warning");

            alert("Subject name is required.");

            return;
        }

        fetch('/Subjects/UpdateInline', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                SLNO: id,
                NAME: name
            })

        })

        .then(res => res.json())

        .then(data => {

            if (data.success) {

                alert(data.message || "Subject updated successfully!");

                location.reload();

            } else {

                alert(data.message || "Update failed");
            }

        })

        .catch(err => {

            alert("Error: " + err);

        });
    }

</script>