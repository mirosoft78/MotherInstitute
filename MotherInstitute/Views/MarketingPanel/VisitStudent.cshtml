@model List<MotherInstitute.Models.MarketingStudent>

@using MotherInstitute.Models

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold text-dark">
            🎯 View Student
        </h2>

    </div>

    <!-- REPORT CARDS -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card shadow border-0 rounded-4 bg-primary text-white">

                <div class="card-body">

                    <h5>Total Students</h5>

                    <h2 class="fw-bold">
                        @ViewBag.TotalStudents
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow border-0 rounded-4 bg-success text-white">

                <div class="card-body">

                    <h5>Visited Students</h5>

                    <h2 class="fw-bold">
                        @ViewBag.VisitedStudents
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow border-0 rounded-4 bg-warning text-dark">

                <div class="card-body">

                    <h5>Initiated Students</h5>

                    <h2 class="fw-bold">
                        @ViewBag.InitiatedStudents
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <!-- SEARCH -->

    <div class="card shadow border-0 rounded-4 mb-4">

        <div class="card-body">

            <form method="get" asp-action="ViewStudent">

                <!-- FIRST ROW -->

                <div class="row">

                    <!-- SCHOOL -->

                    <div class="col-md-3 mb-3">

                        <label class="fw-bold mb-2">
                            Select School
                        </label>

                        <select name="schoolId"
                                class="form-select">

                            <option value="">
                                -- All Schools --
                            </option>

                            @foreach (var school in (List<SchoolMaster>)ViewBag.Schools)
                            {
                                <option value="@school.ID"
                                        selected="@(Context.Request.Query["schoolId"] == school.ID.ToString())">

                                    @school.SchoolName

                                </option>
                            }

                        </select>

                    </div>

                    <!-- DISTRICT -->

                    <div class="col-md-3 mb-3 position-relative">

                        <label class="fw-bold mb-2">
                            Select District
                        </label>

                        <input type="text"
                               id="districtSearch"
                               name="district"
                               class="form-control"
                               placeholder="Search district..."
                               autocomplete="off"
                               value="@Context.Request.Query["district"]" />

                        <div id="districtDropdown"
                             class="bg-white border rounded shadow-sm mt-1"
                             style="
                            display:none;
                            max-height:220px;
                            overflow-y:auto;
                            position:absolute;
                            width:92%;
                            z-index:9999;">

                            @foreach (var district in ((List<SchoolMaster>)ViewBag.Schools)
                                                            .Select(x => x.District)
                                                            .Where(x => !string.IsNullOrEmpty(x))
                                                            .Distinct()
                                                            .OrderBy(x => x))
                            {
                                <div class="district-item p-2"
                                     style="
                                    cursor:pointer;
                                    border-bottom:1px solid #eee;"
                                     onclick="selectDistrict('@district')">

                                    @district

                                </div>
                            }

                        </div>

                    </div>

                    <!-- BLOCK -->

                    <div class="col-md-3 mb-3 position-relative">

                        <label class="fw-bold mb-2">
                            Select Block
                        </label>

                        <input type="text"
                               id="blockSearch"
                               name="block"
                               class="form-control"
                               placeholder="Search block..."
                               autocomplete="off"
                               value="@Context.Request.Query["block"]" />

                        <div id="blockDropdown"
                             class="bg-white border rounded shadow-sm mt-1"
                             style="
                            display:none;
                            max-height:220px;
                            overflow-y:auto;
                            position:absolute;
                            width:92%;
                            z-index:9999;">

                            @foreach (var block in ((List<SchoolMaster>)ViewBag.Schools)
                                                            .Where(x =>
                                                                string.IsNullOrEmpty(Context.Request.Query["district"])
                                                                || x.District == Context.Request.Query["district"])
                                                            .Select(x => x.Block)
                                                            .Where(x => !string.IsNullOrEmpty(x))
                                                            .Distinct()
                                                            .OrderBy(x => x))
                            {
                                <div class="block-item p-2"
                                     style="
                                    cursor:pointer;
                                    border-bottom:1px solid #eee;"
                                     onclick="selectBlock('@block')">

                                    @block

                                </div>
                            }

                        </div>

                    </div>

                    <!-- STATUS -->

                    <div class="col-md-3 mb-3">

                        <label class="fw-bold mb-2">
                            Filter Status
                        </label>

                        <select name="status"
                                class="form-select">

                            <option value="">
                                -- All Status --
                            </option>

                            <option value="Initiated"
                                    selected="@(Context.Request.Query["status"] == "Initiated")">
                                Initiated
                            </option>

                            <option value="Visited"
                                    selected="@(Context.Request.Query["status"] == "Visited")">
                                Visited
                            </option>

                            <option value="Final"
                                    selected="@(Context.Request.Query["status"] == "Final")">
                                Final
                            </option>

                            <option value="Cancel"
                                    selected="@(Context.Request.Query["status"] == "Cancel")">
                                Cancel
                            </option>

                        </select>

                    </div>

                </div>

                <!-- SECOND ROW -->

                <div class="row mt-2">

                    <!-- STUDENT SEARCH -->

                    <div class="col-md-6 mb-3 position-relative">

                        <label class="fw-bold mb-2">
                            Search Student
                        </label>

                        <input type="text"
                               name="studentName"
                               id="studentSearch"
                               class="form-control"
                               placeholder="Search student name..."
                               autocomplete="off"
                               value="@Context.Request.Query["studentName"]" />

                        <div id="studentDropdown"
                             class="bg-white border rounded shadow-sm mt-1"
                             style="
                            display:none;
                            max-height:220px;
                            overflow-y:auto;
                            position:absolute;
                            width:92%;
                            z-index:9999;">

                            @foreach (var student in Model
                                                            .Select(x => x.StudentName)
                                                            .Where(x => !string.IsNullOrEmpty(x))
                                                            .Distinct()
                                                            .OrderBy(x => x))
                            {
                                <div class="student-item p-2"
                                     style="
                                    cursor:pointer;
                                    border-bottom:1px solid #eee;"
                                     onclick="selectStudent('@student')">

                                    @student

                                </div>
                            }

                        </div>

                    </div>

                    <!-- SEARCH BUTTON -->

                    <div class="col-md-2 mb-3 d-flex align-items-end">

                        <button type="submit"
                                class="btn btn-primary rounded-pill px-4 w-100">

                            🔍 Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- TABLE -->

    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>ID</th>
                            <th>School</th>
                            <th>District</th>
                            <th>Block</th>
                            <th>Student Name</th>
                            <th>Phone</th>
                            <th>Address</th>
                            <th>Note</th>
                            <th>Status</th>
                            <th>Initiated Date</th>
                            <th>Visited Date</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Count > 0)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.ID</td>

                                    <td>
                                        @item.SchoolMaster?.SchoolName
                                    </td>

                                    <td>
                                        @item.SchoolMaster?.District
                                    </td>

                                    <td>
                                        @item.SchoolMaster?.Block
                                    </td>

                                    <td class="fw-semibold">
                                        @item.StudentName
                                    </td>

                                    <td>
                                        @item.PhoneNumber
                                    </td>

                                    <td>
                                        @item.Address
                                    </td>

                                    <td style="min-width:250px;">
                                        @item.Note
                                    </td>

                                    <td>

                                        @if (item.Status == "Visited")
                                        {
                                            <span class="badge bg-success px-3 py-2">
                                                @item.Status
                                            </span>
                                        }
                                        else if (item.Status == "Final")
                                        {
                                            <span class="badge bg-primary px-3 py-2">
                                                @item.Status
                                            </span>
                                        }
                                        else if (item.Status == "Cancel")
                                        {
                                            <span class="badge bg-danger px-3 py-2">
                                                @item.Status
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">
                                                @item.Status
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        @item.InitiatedDate?.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>

                                        @if (item.VisitedDate != null)
                                        {
                                            @item.VisitedDate?.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="11"
                                    class="text-center text-muted py-4">

                                    No student data found

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<script>

    // STUDENT SEARCH

    const searchInput =
        document.getElementById("studentSearch");

    const dropdown =
        document.getElementById("studentDropdown");

    const items =
        document.querySelectorAll(".student-item");

    searchInput.addEventListener("keyup", function () {

        let value = this.value.toLowerCase();

        if (value.trim() === "") {

            dropdown.style.display = "none";
            return;
        }

        let hasVisible = false;

        items.forEach(item => {

            let text = item.innerText.toLowerCase();

            if (text.includes(value)) {

                item.style.display = "block";
                hasVisible = true;
            }
            else {

                item.style.display = "none";
            }

        });

        dropdown.style.display =
            hasVisible ? "block" : "none";

    });

    function selectStudent(name) {

        searchInput.value = name;
        dropdown.style.display = "none";
    }

    // DISTRICT SEARCH

    const districtSearch =
        document.getElementById("districtSearch");

    const districtDropdown =
        document.getElementById("districtDropdown");

    const districtItems =
        document.querySelectorAll(".district-item");

    districtSearch.addEventListener("keyup", function () {

        let value = this.value.toLowerCase();

        if (value.trim() === "") {

            districtDropdown.style.display = "none";
            return;
        }

        let hasVisible = false;

        districtItems.forEach(item => {

            let text = item.innerText.toLowerCase();

            if (text.includes(value)) {

                item.style.display = "block";
                hasVisible = true;
            }
            else {

                item.style.display = "none";
            }

        });

        districtDropdown.style.display =
            hasVisible ? "block" : "none";

    });

    function selectDistrict(name) {

        districtSearch.value = name;
        districtDropdown.style.display = "none";
    }

    // BLOCK SEARCH

    const blockSearch =
        document.getElementById("blockSearch");

    const blockDropdown =
        document.getElementById("blockDropdown");

    const blockItems =
        document.querySelectorAll(".block-item");

    blockSearch.addEventListener("keyup", function () {

        let value = this.value.toLowerCase();

        if (value.trim() === "") {

            blockDropdown.style.display = "none";
            return;
        }

        let hasVisible = false;

        blockItems.forEach(item => {

            let text = item.innerText.toLowerCase();

            if (text.includes(value)) {

                item.style.display = "block";
                hasVisible = true;
            }
            else {

                item.style.display = "none";
            }

        });

        blockDropdown.style.display =
            hasVisible ? "block" : "none";

    });

    function selectBlock(name) {

        blockSearch.value = name;
        blockDropdown.style.display = "none";
    }

    // OUTSIDE CLICK

    document.addEventListener("click", function (e) {

        if (!searchInput.contains(e.target) &&
            !dropdown.contains(e.target)) {

            dropdown.style.display = "none";
        }

        if (!districtSearch.contains(e.target) &&
            !districtDropdown.contains(e.target)) {

            districtDropdown.style.display = "none";
        }

        if (!blockSearch.contains(e.target) &&
            !blockDropdown.contains(e.target)) {

            blockDropdown.style.display = "none";
        }

    });

</script>