@model IEnumerable<MotherInstitute.Models.Course>

@{
    ViewData["Title"] = "Manage Course";
}

<div class="main-content-box">

    <style>

            .page-header {
                padding: 8px 16px;
                border-radius: 10px;
                background: linear-gradient(90deg, #0b5ed7, #1ec8ff);
                margin-bottom: 10px;
            }

                .page-header h2 {
                    margin: 0;
                    font-size: 22px;
                    color: white;
                    text-align: center;
                    font-weight: 700;
                }

            .page-form-row {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 12px;
                flex-wrap: wrap;
            }

                .page-form-row label {
                    font-size: 13px;
                    font-weight: 600;
                    color: #374151;
                }

                .page-form-row input[type="text"] {
                    width: 220px;
                    height: 30px;
                    padding: 4px 8px;
                    border: 1px solid #d1d5db;
                    border-radius: 5px;
                    font-size: 12px;
                    outline: none;
                }

                .page-form-row button {
                    background: #2563eb;
                    color: white;
                    border: none;
                    padding: 5px 14px;
                    border-radius: 5px;
                    font-size: 12px;
                    font-weight: 600;
                    cursor: pointer;
                    height: 30px;
                }

                    .page-form-row button:hover {
                        background: #1d4ed8;
                    }

            .empty-field-warning {
                border: 1px solid red !important;
                box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.18) !important;
            }

            .course-table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 6px;
                background: white;
                border-radius: 8px;
                overflow: hidden;
            }

                .course-table thead tr {
                    background: #1e40af;
                }

                .course-table th {
                    color: white;
                    padding: 6px 8px;
                    text-align: center;
                    font-size: 12px;
                    font-weight: 700;
                    height: 30px;
                    border-right: 1px solid rgba(255,255,255,0.10);
                    white-space: nowrap;
                }

                .course-table td {
                    padding: 5px 8px;
                    border-bottom: 1px solid #e5e7eb;
                    vertical-align: middle;
                    font-size: 12px;
                    text-align: center;
                    height: 32px;
                    line-height: 1.1;
                    white-space: nowrap;
                }

                .course-table tbody tr:nth-child(even) {
                    background: #fafafa;
                }

                .course-table tbody tr:hover {
                    background: #edf4ff;
                }

            .action-icon {
                width: 18px;
                height: 18px;
                cursor: pointer;
            }

            .inline-edit-box {
                width: 140px;
                height: 24px;
                padding: 2px 5px;
                border: 1px solid #d1d5db;
                border-radius: 4px;
                font-size: 11px;
            }

    </style>

    <div class="page-header">
        <h2>Manage Course</h2>
    </div>

    <form asp-action="Create"
          method="post"
          class="page-form-row"
          id="courseForm">

        <label>Course Name</label>

        <div style="display:flex; flex-direction:column;">

            <input type="text"
                   name="NAME"
                   id="COURSE_NAME"
                   oninput="validateCourseName(this)" />

            <span id="courseNameError"
                  class="text-danger"
                  style="font-size:12px; margin-top:4px;">
            </span>

        </div>

        <button type="submit">
            Add
        </button>

    </form>

    <table class="course-table">

        <thead>

            <tr>
                <th>Edit</th>
                <th>Name</th>
                <th>Delete</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td style="text-align:center; white-space:nowrap;">

                        <img src="~/images/edit.png"
                             onclick="editRow(this)"
                             class="action-icon" />

                        <img src="~/images/update.png"
                             onclick="updateRow(this, '@item.SLNO')"
                             class="action-icon"
                             style="display:none;" />

                        <img src="~/images/cancel.png"
                             onclick="cancelEdit(this)"
                             class="action-icon"
                             style="display:none; margin-left:4px;" />

                    </td>

                    <td>

                        <span>@item.NAME</span>

                        <input type="text"
                               value="@item.NAME"
                               class="inline-edit-box"
                               style="display:none;"
                               oninput="this.value=this.value.replace(/[^A-Za-z\s]/g,'');" />

                    </td>

                    <td style="text-align:center;">

                        <form asp-action="Delete"
                              method="post"
                              style="display:inline;"
                              onsubmit="return confirm('Are you sure you want to delete this course?');">

                            <input type="hidden"
                                   name="id"
                                   value="@item.SLNO" />

                            <button type="submit"
                                    style="border:none; background:none; padding:0;">

                                <img src="~/images/delete.png"
                                     class="action-icon" />

                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        var successMessage = '@TempData["SuccessMessage"]';
        var errorMessage = '@TempData["ErrorMessage"]';

        if (successMessage && successMessage !== '') {
            alert(successMessage);
        }

        if (errorMessage && errorMessage !== '') {
            alert(errorMessage);
        }

        var courseForm = document.getElementById("courseForm");
        var courseName = document.getElementById("COURSE_NAME");

        if (courseForm) {

            courseForm.addEventListener("submit", function (e) {

                courseName.classList.remove("empty-field-warning");

                if (courseName.value.trim() === "") {

                    courseName.classList.add("empty-field-warning");

                    if (!confirm("Course Name is empty. Continue?")) {

                        e.preventDefault();
                    }
                }

            });

        }

    });

    function editRow(btn) {

        let row = btn.closest("tr");

        btn.style.display = "none";

        row.children[0].children[1].style.display = "inline";
        row.children[0].children[2].style.display = "inline";

        let span = row.children[1].children[0];
        let input = row.children[1].children[1];

        span.style.display = "none";
        input.style.display = "inline-block";

    }

    function cancelEdit(btn) {

        let row = btn.closest("tr");

        row.children[0].children[0].style.display = "inline";
        row.children[0].children[1].style.display = "none";
        row.children[0].children[2].style.display = "none";

        let span = row.children[1].children[0];
        let input = row.children[1].children[1];

        input.value = span.innerText;

        span.style.display = "inline";
        input.style.display = "none";

    }

    function updateRow(btn, id) {

        alert("Course name cannot be modified.\n\nPlease delete this course and add a new course.");

        return;

    }
        function validateCourseName(input) {

        var error = document.getElementById("courseNameError");

        var originalValue = input.value;

        input.value = input.value.replace(/[^A-Za-z\s]/g, '');

        if (originalValue !== input.value) {

            error.innerHTML = "Only letters are allowed.";

        } else {

            error.innerHTML = "";
        }
    }

</script>