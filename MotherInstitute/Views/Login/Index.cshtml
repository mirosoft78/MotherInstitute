@model MotherInstitute.Models.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
            * {
                box-sizing: border-box;
            }

            html, body {
                margin: 0;
                padding: 0;
                min-height: 100%;
                font-family: Arial, Helvetica, sans-serif;
            }

            body {
                min-height: 100vh;
                overflow: hidden;
                background: radial-gradient(circle at 10% 15%, rgba(61,115,255,0.45) 0 16%, transparent 17%), radial-gradient(circle at 90% 50%, rgba(30,106,255,0.28) 0 18%, transparent 19%), linear-gradient(135deg, #0c2c74 0%, #082460 38%, #051848 100%);
                position: relative;
            }

                body::before,
                body::after {
                    content: "";
                    position: absolute;
                    inset: 0;
                    pointer-events: none;
                }

                body::before {
                    background: radial-gradient(circle at -5% 80%, rgba(70,120,255,0.35) 0 22%, transparent 23%), radial-gradient(circle at 110% 35%, rgba(31,90,214,0.35) 0 24%, transparent 25%), radial-gradient(circle at 30% -10%, rgba(42,88,195,0.28) 0 20%, transparent 21%);
                }

                body::after {
                    opacity: 0.22;
                    background: linear-gradient(115deg, transparent 0%, transparent 18%, rgba(255,255,255,0.16) 18.5%, transparent 19%);
                    transform: translateY(80px);
                }

            .overlay {
                display: flex;
                justify-content: center;
                align-items: center;
                flex-direction: column;
                min-height: 100vh;
                padding: 20px;
                text-align: center;
                color: #fff;
            }

            /* 🔽 REDUCED SIZE */
            .main-title {
                font-size: 34px;
                font-weight: 800;
                margin-bottom: 6px;
            }

            .sub-title {
                font-size: 15px;
                margin-bottom: 25px;
                opacity: 0.9;
            }

            .login-box {
                max-width: 380px;
                width: 100%;
                background: rgba(3, 14, 44, 0.86);
                border-radius: 10px;
                padding: 28px;
                text-align: left;
                box-shadow: 0 12px 30px rgba(0,0,0,0.4);
            }

                .login-box h2 {
                    text-align: center;
                    margin-bottom: 20px;
                    font-size: 22px;
                    font-weight: 700;
                }

            .form-group {
                margin-bottom: 14px;
            }

                .form-group label {
                    font-size: 14px;
                    font-weight: 600;
                    margin-bottom: 6px;
                    display: block;
                }

            .form-control {
                width: 100%;
                height: 44px;
                padding: 10px;
                border-radius: 5px;
                border: none;
                font-size: 14px;
                background: #f3f3f3;
            }

                .form-control:focus {
                    outline: none;
                    box-shadow: 0 0 0 2px rgba(81,155,255,0.3);
                }

            .login-btn {
                width: 100%;
                height: 44px;
                border: none;
                border-radius: 5px;
                background: #26c654;
                color: white;
                font-size: 15px;
                font-weight: 600;
                cursor: pointer;
                margin-top: 5px;
            }

                .login-btn:hover {
                    background: #1fa747;
                }

            .error-box {
                background: #f8d7da;
                color: #721c24;
                padding: 10px;
                border-radius: 5px;
                margin-bottom: 12px;
                text-align: center;
                font-size: 13px;
            }

            .field-validation-error {
                color: #ffb9b9;
                font-size: 12px;
            }

            @@media (max-width: 768px) {
                body {
                    overflow: auto;
                }

                .main-title {
                    font-size: 26px;
                }

                .login-box {
                    padding: 20px;
                }
            }
    </style>
</head>

<body>
    <div class="overlay">
        <div class="main-title">LOGIN TO OUR SITE</div>
        <div class="sub-title">
            Use the form below to login to our website if you have an account.
        </div>

        <div class="login-box">
            <h2>SIGN IN</h2>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="error-box">@ViewBag.ErrorMessage</div>
            }

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Username</label>
                    <input asp-for="Username" class="form-control" placeholder="Enter username" />
                    <span asp-validation-for="Username"></span>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <button type="submit" class="login-btn">Sign In</button>
            </form>
        </div>
    </div>
</body>
</html>