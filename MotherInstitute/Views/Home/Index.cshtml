@{
    ViewData["Title"] = "Home";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>

    /* ================= GLOBAL ================= */

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html,
    body {
        width: 100%;
        overflow-x: hidden;
        background: #f5f7fb;
        font-family: 'Segoe UI',sans-serif;
    }

    /* REMOVE BOOTSTRAP SIDE GAP */

    .container,
    .container-fluid {
        width: 100% !important;
        max-width: 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    /* ================= MAIN CONTENT ================= */

    .main-content {
        width: 100%;
        padding: 0;
        margin: 0;
    }

    /* ================= COMMON SECTION ================= */

    .about-section,
    .facility-section,
    .testimonial-section,
    .student-result-section,
    .footer-section {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        padding: 90px 70px;
    }

    /* ================= HERO SECTION ================= */

    html,
    body {
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden;
    }

    .home-box {
        margin: 0 !important;
        padding: 0 !important;
        width: 100%;
    }

    .container,
    .container-fluid {
        padding-left: 0 !important;
        padding-right: 0 !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
        max-width: 100% !important;
    }

    .main-content {
        margin: 0 !important;
        padding: 0 !important;
        width: 100%;
    }

    .hero-slider {
        position: relative;
        width: 100%;
        overflow: hidden;
        margin: 0;
        padding: 0;
    }

    .slide {
        position: absolute;
        width: 100%;
        opacity: 0;
        transition: 1s;
        top: 0;
        left: 0;
    }

        .slide.active {
            opacity: 1;
            position: relative;
            z-index: 2;
        }

        .slide img {
            width: 100%;
            height: auto;
            display: block;
        }

    .hero-content {
        position: absolute;
        left: 70px;
        bottom: 80px;
        z-index: 5;
        color: #fff;
        max-width: 700px;
    }

        .hero-content h1 {
            font-size: 68px;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 18px;
        }

        .hero-content p {
            font-size: 24px;
            line-height: 1.8;
        }
    /* ================= SECTION TITLES ================= */

    .home-section-title {
        text-align: center;
        font-size: 54px;
        font-weight: 800;
        color: #203864;
        margin-bottom: 15px;
    }

    .home-subtitle {
        text-align: center;
        font-size: 22px;
        color: #6b7280;
        margin-bottom: 60px;
    }

    /* ================= ABOUT ================= */

    .about-section {
        background: #fff;
    }

    .about-image-box {
        position: relative;
        max-width: 620px;
        margin: auto;
    }

    .about-main-img {
        width: 100%;
        height: 520px;
        object-fit: cover;
        border-radius: 24px;
    }

    .about-small-img {
        position: absolute;
        width: 270px;
        height: 210px;
        object-fit: cover;
        right: -25px;
        bottom: -25px;
        border-radius: 22px;
        border: 8px solid #fff;
    }

    .about-title {
        font-size: 42px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 22px;
        line-height: 1.3;
    }

    .about-text {
        font-size: 18px;
        line-height: 1.9;
        color: #4b5563;
        margin-bottom: 20px;
    }

    .about-btn {
        display: inline-block;
        background: #2196f3;
        color: #fff;
        padding: 14px 34px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        transition: .3s;
    }

        .about-btn:hover {
            background: #1565c0;
            transform: translateY(-3px);
        }

    /* ================= FACILITY ================= */

    .facility-section {
        background: linear-gradient(rgba(82,0,168,.75),rgba(82,0,168,.75)), url('/images/clasrrom.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

        .facility-section .home-section-title,
        .facility-section .home-subtitle {
            color: #fff;
        }

    .home-card-row {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 28px;
    }

    .home-card {
        width: 310px;
        background: #fff;
        border-radius: 24px;
        padding: 35px 28px;
        text-align: center;
        transition: .3s;
        box-shadow: 0 10px 30px rgba(0,0,0,.15);
    }

        .home-card:hover {
            transform: translateY(-8px);
        }

    .home-icon {
        font-size: 58px;
        margin-bottom: 20px;
    }

    .home-card h3 {
        font-size: 30px;
        font-weight: 800;
        color: #4b0082;
        margin-bottom: 16px;
    }

    .home-card p {
        font-size: 18px;
        line-height: 1.8;
        color: #444;
    }

    /* ================= TESTIMONIAL ================= */

    .testimonial-section {
        background: linear-gradient(rgba(68,0,128,.82),rgba(68,0,128,.82)), url('/images/banner.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .testimonial-header {
        margin-bottom: 55px;
        text-align: center;
    }

        .testimonial-header h2 {
            font-size: 52px;
            color: #fff;
            font-weight: 800;
            margin-bottom: 18px;
        }

        .testimonial-header p {
            color: rgba(255,255,255,.92);
            font-size: 21px;
            line-height: 1.8;
        }

    .testimonial-card {
        background: #fff;
        border-radius: 22px;
        padding: 32px;
        transition: .3s;
        height: 100%;
    }

        .testimonial-card:hover {
            transform: translateY(-8px);
        }

    /* ================= STUDENT RESULT ================= */

    .student-result-section {
        background: #fff;
    }

    .student-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
        gap: 28px;
        margin-top: 55px;
    }

    .student-card {
        position: relative;
        height: 380px;
        border-radius: 20px;
        overflow: hidden;
        background: #fff;
        transition: .35s;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
    }

        .student-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 35px rgba(0,0,0,.14);
        }

        .student-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center 20%;
            transition: .4s;
        }

        .student-card:hover img {
            transform: scale(1.02);
        }

    .student-overlay {
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        padding: 20px 18px;
        background: linear-gradient(to top, rgba(0,0,0,.88), rgba(0,0,0,.35), transparent);
        text-align: center;
    }

    .student-rank {
        display: inline-block;
        background: rgba(255,255,255,.18);
        color: #fff;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .student-overlay h3 {
        font-size: 22px;
        font-weight: 800;
        color: #fff;
        margin-bottom: 8px;
    }

    .student-marks {
        font-size: 16px;
        color: rgba(255,255,255,.92);
        font-weight: 600;
        margin-bottom: 10px;
    }

    .student-desc {
        font-size: 14px;
        line-height: 1.6;
        color: rgba(255,255,255,.88);
    }
    
    /* ================= Achivement ================= */
    .achievement-box {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#4a148c,#6a1b9a);
        overflow: hidden;
        position: relative;
        grid-column: span 2;
    }

        .achievement-box::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
            top: -80px;
            right: -80px;
        }

    .achievement-content {
        text-align: center;
        z-index: 2;
        padding: 30px;
    }

    .achievement-title {
        color: white;
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 25px;
    }

    .achievement-text {
        color: #fff;
        font-size: 30px;
        font-weight: 700;
        transition: 0.5s;
    }

    /* ================= FOOTER ================= */

    .footer-section {
        background: #1b1b1f;
        padding: 70px 80px;
    }

    .footer-container {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 120px;
    }

    .footer-title {
        color: #00a2ff;
        font-size: 34px;
        font-weight: 700;
        margin-bottom: 35px;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .footer-links li {
            margin-bottom: 22px;
        }

        .footer-links a {
            color: #f5f5f5;
            text-decoration: none;
            font-size: 22px;
            transition: .3s;
        }

            .footer-links a:hover {
                color: #00a2ff;
                padding-left: 6px;
            }

    .footer-contact p {
        color: #f5f5f5;
        font-size: 22px;
        line-height: 1.9;
        margin-bottom: 28px;
    }

    .footer-contact i {
        color: #00a2ff;
        margin-right: 14px;
        font-size: 22px;
    }

    /* ================= MOBILE ================= */

    @@media(max-width:768px) {

        .hero-slider {
            height: auto !important;
            min-height: auto !important;
            overflow: hidden;
        }

        .slide {
            position: relative !important;
            opacity: 1 !important;
            display: none;
        }

            .slide.active {
                display: block;
            }

            .slide img {
                width: 100%;
                height: auto;
                display: block;
                object-fit: cover;
            }

        .hero-content {
            left: 25px;
            bottom: 35px;
            max-width: 90%;
        }

            .hero-content h1 {
                font-size: 34px;
            }

            .hero-content p {
                font-size: 16px;
            }

        .about-section,
        .facility-section,
        .testimonial-section,
        .student-result-section,
        .footer-section {
            padding: 60px 20px;
        }

        .footer-container {
            grid-template-columns: 1fr;
            gap: 50px;
        }

        .home-section-title {
            font-size: 36px;
        }

        .home-subtitle {
            font-size: 17px;
        }

        .student-card {
            height: 350px;
        }

        .achievement-box {
            grid-column: span 1;
        }
    }

</style>

