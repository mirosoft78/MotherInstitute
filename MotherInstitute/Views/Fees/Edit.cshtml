@model MotherInstitute.Models.Fees

@{
    ViewData["Title"] = "Edit Fees";
}

<h2>Edit Fees</h2>

<form asp-action="Edit" method="post">
    <input asp-for="SLNO" type="hidden" />

    <div style="margin-bottom:15px;">
        <label>Fees Name</label><br />
        <input asp-for="NAME" />
    </div>

    <button type="submit">Update</button>
    <a asp-action="Index" style="margin-left:10px;">Cancel</a>
</form>