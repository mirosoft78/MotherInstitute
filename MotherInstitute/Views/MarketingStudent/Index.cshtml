@model List<MotherInstitute.Models.MarketingStudent>

@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Marketing Student";

    var editData = ViewBag.EditData as MotherInstitute.Models.MarketingStudent;
}

<style>

    .container-fluid {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

</style>

<div class="container-fluid px-0">

    <div style="
        border:3px solid red;
        border-radius:30px;
        overflow:hidden;
        background:#f7f7f7;">

        <!-- HEADER -->

        <div style="
            background:linear-gradient(90deg,#1d5fe3,#2fc4ef);
            padding:12px;
            text-align:center;">

            <h2 style="
                color:white;
                margin:0;
                font-size:18px;
                font-weight:700;">

                Manage Marketing Student

            </h2>

        </div>
        <!-- FORM -->
        @if (editData == null)
        {
            <form asp-action="Save"
                  method="post"
                  style="padding:18px;">

                @Html.AntiForgeryToken()

                <div class="row">

                    <!-- SCHOOL -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex align-items-center">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-bottom:0;">

                                School Name

                            </label>

                            <select name="SchoolId"
                                    class="form-control"
                                    required
                                    style="
                                height:38px;
                                font-size:12px;
                                border-radius:6px;">

                                <option value="">
                                    -- Select School --
                                </option>

                                @foreach (var item in (SelectList)ViewBag.Schools)
                                {
                                    <option value="@item.Value">
                                        @item.Text
                                    </option>
                                }

                            </select>

                        </div>

                    </div>

                    <!-- STUDENT -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex align-items-center">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-bottom:0;">

                                Student Name

                            </label>

                            <div style="width:100%;">

                                <input type="text"
                                       name="StudentName"
                                       class="form-control"
                                       oninput="validateStudentName(this)" />

                                <span id="studentNameError"
                                      style="
                                    color:red;
                                    font-size:14px;
                                    display:block;
                                    margin-top:4px;">
                                </span>

                            </div>

                        </div>

                    </div>

                    <!-- AGENT -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex align-items-center">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-bottom:0;">

                                Agent Name

                            </label>

                            <select name="AgentName"
                                    class="form-control"
                                    required
                                    style="
                                height:38px;
                                font-size:12px;
                                border-radius:6px;">

                                <option value="">
                                    -- Select Agent --
                                </option>

                                @foreach (var item in (SelectList)ViewBag.Agents)
                                {
                                    <option value="@item.Text">
                                        @item.Text
                                    </option>
                                }

                            </select>

                        </div>

                    </div>

                    <!-- PHONE -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex align-items-center">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-bottom:0;">

                                Phone Number

                            </label>

                            <div style="width:100%;">

                                <input type="text"
                                       name="PhoneNumber"
                                       maxlength="10"
                                       class="form-control"
                                       oninput="validatePhoneNumber(this)"
                                       style="
                                height:38px;
                                font-size:12px;
                                border-radius:6px;" />

                                <span id="phoneNumberError"
                                      style="
                                    color:red;
                                    font-size:14px;
                                    display:block;
                                    margin-top:4px;">
                                </span>

                            </div>

                        </div>

                    </div>

                    <!-- SESSION -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex align-items-center">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-bottom:0;">

                                Session

                            </label>

                            <input type="number"
                                   name="Session"
                                   class="form-control"
                                   placeholder="2025"
                                   style="
                            height:38px;
                            font-size:12px;
                            border-radius:6px;" />

                        </div>

                    </div>

                    <!-- ADDRESS -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex align-items-center">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-bottom:0;">

                                Address

                            </label>

                            <input type="text"
                                   name="Address"
                                   class="form-control"
                                   style="
                            height:38px;
                            font-size:12px;
                            border-radius:6px;" />

                        </div>

                    </div>

                    <!-- NOTE -->

                    <div class="col-md-6 mb-3">

                        <div class="d-flex">

                            <label style="
                                width:140px;
                                font-size:12px;
                                font-weight:600;
                                margin-top:10px;">

                                Note

                            </label>

                            <textarea name="Note"
                                      class="form-control"
                                      rows="3"
                                      style="
                            font-size:12px;
                            border-radius:6px;"></textarea>

                        </div>

                    </div>

                </div>

                <!-- BUTTON -->

                <button type="submit"
                        class="btn btn-primary"
                        style="
                    height:40px;
                    padding:0 25px;
                    border-radius:8px;
                    font-size:12px;
                    font-weight:600;
                    margin-left:140px;">

                    Save Student

                </button>

            </form>
        }

        <!-- TITLE -->

        <div style="
            text-align:center;
            margin-top:10px;
            margin-bottom:10px;">

            <h3 style="
                color:#2c5dea;
                font-size:18px;
                font-weight:700;">

                Saved Marketing Student Data

            </h3>

        </div>

        <!-- TABLE -->

        <table class="text-center align-middle mb-0"
               style="
                    width:100%;
                    margin:0;
                    border-collapse:collapse;
                    table-layout:auto;
                    font-size:11px;">

            <!-- HEADER -->

            <thead>

                <tr style="
                    background:#2947b8;
                    color:white;
                    height:45px;">

                    <th style="background:#2947b8;color:white;">Edit</th>
                    <th style="background:#2947b8;color:white;">ID</th>
                    <th style="background:#2947b8;color:white;">School</th>
                    <th style="background:#2947b8;color:white;">Student Name</th>
                    <th style="background:#2947b8;color:white;">Agent Name</th>
                    <th style="background:#2947b8;color:white;">Phone</th>
                    <th style="background:#2947b8;color:white;">Session</th>
                    <th style="background:#2947b8;color:white;">Address</th>
                    <th style="background:#2947b8;color:white;">Note</th>
                    <th style="background:#2947b8;color:white;">Status</th>
                    <th style="background:#2947b8;color:white;">Initiated Date</th>
                    <th style="background:#2947b8;color:white;">Visited Date</th>
                    <th style="background:#2947b8;color:white;">Delete</th>

                </tr>

            </thead>

            <!-- BODY -->

            <tbody>

                @foreach (var item in Model)
                {
                    if (editData != null && editData.ID == item.ID)
                    {
                        <tr style="
                            height:48px;
                            font-size:11px;">

                            <form asp-action="Save"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="ID"
                                       value="@item.ID" />

                                <!-- EDIT -->

                                <td style="border:1px solid #d9d9d9;">

                                    <button type="submit"
                                            style="border:none;background:none;">

                                        <img src="~/images/update.png"
                                             width="26" />

                                    </button>

                                    <a asp-action="Index">

                                        <img src="~/images/cancel.png"
                                             width="26" />

                                    </a>

                                </td>

                                <td style="border:1px solid #d9d9d9;">
                                    @item.ID
                                </td>

                                <!-- SCHOOL -->

                                <td style="border:1px solid #d9d9d9;">

                                    <select name="SchoolId"
                                            class="form-control"
                                            style="font-size:11px;">

                                        @foreach (var school in (SelectList)ViewBag.Schools)
                                        {
                                            if (school.Value == item.SchoolId.ToString())
                                            {
                                                <option value="@school.Value" selected>
                                                    @school.Text
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@school.Value">
                                                    @school.Text
                                                </option>
                                            }
                                        }

                                    </select>

                                </td>

                                <!-- STUDENT -->

                                <td style="border:1px solid #d9d9d9;">

                                    <input type="text"
                                           name="StudentName"
                                           value="@item.StudentName"
                                           class="form-control"
                                           style="font-size:11px;" />

                                </td>

                                <!-- AGENT -->

                                <td style="border:1px solid #d9d9d9;">

                                    <select name="AgentName"
                                            class="form-control"
                                            style="font-size:11px;">

                                        @foreach (var agent in (SelectList)ViewBag.Agents)
                                        {
                                            if (agent.Text == item.AgentName)
                                            {
                                                <option value="@agent.Text" selected>
                                                    @agent.Text
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@agent.Text">
                                                    @agent.Text
                                                </option>
                                            }
                                        }

                                    </select>

                                </td>

                                <!-- PHONE -->

                                <td style="border:1px solid #d9d9d9;">

                                    <input type="text"
                                           name="PhoneNumber"
                                           value="@item.PhoneNumber"
                                           class="form-control"
                                           style="font-size:11px;" />

                                </td>
                                <!-- SESSION -->

                                <td style="border:1px solid #d9d9d9;">

                                    <input type="number"
                                           name="Session"
                                           value="@item.Session"
                                           class="form-control"
                                           style="font-size:11px;" />

                                </td>

                                <!-- ADDRESS -->

                                <td style="border:1px solid #d9d9d9;">

                                    <input type="text"
                                           name="Address"
                                           value="@item.Address"
                                           class="form-control"
                                           style="font-size:11px;" />

                                </td>

                                <!-- NOTE -->

                                <td style="border:1px solid #d9d9d9;">

                                    <input type="text"
                                           name="Note"
                                           value="@item.Note"
                                           class="form-control"
                                           style="font-size:11px;" />

                                </td>

                                <!-- STATUS -->

                                <td style="border:1px solid #d9d9d9;">

                                    <select name="Status"
                                            class="form-control"
                                            style="font-size:11px;">

                                        <option value="Initiated" selected="@(item.Status=="Initiated")">Initiated</option>
                                        <option value="Visited" selected="@(item.Status=="Visited")">Visited</option>
                                        <option value="Final" selected="@(item.Status=="Final")">Final</option>
                                        <option value="Cancel" selected="@(item.Status=="Cancel")">Cancel</option>

                                    </select>

                                </td>

                                <!-- DATES -->

                                <td style="border:1px solid #d9d9d9;">
                                    @item.InitiatedDate?.ToString("dd/MM/yyyy")
                                </td>

                                <td style="border:1px solid #d9d9d9;">

                                    @if (item.VisitedDate != null)
                                    {
                                        @item.VisitedDate?.ToString("dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }

                                </td>

                                <!-- DELETE -->

                                <td style="border:1px solid #d9d9d9;">

                                    <a asp-action="Delete"
                                       asp-route-id="@item.ID"
                                       onclick="return confirm('Are you sure?')">

                                        <img src="~/images/delete.png"
                                             width="26" />

                                    </a>

                                </td>

                            </form>

                        </tr>
                    }
                    else
                    {
                        <tr style="
                            height:48px;
                            font-size:11px;
                            font-weight:500;">

                            <td style="border:1px solid #d9d9d9;">

                                <a asp-action="Edit"
                                   asp-route-id="@item.ID">

                                    <img src="~/images/edit.png"
                                         width="26" />

                                </a>

                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.ID
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.SchoolMaster?.SchoolName
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.StudentName
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.AgentName
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.PhoneNumber
                            </td>
                            <td style="border:1px solid #d9d9d9;">
                                @item.Session
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.Address
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.Note
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.Status
                            </td>

                            <td style="border:1px solid #d9d9d9;">
                                @item.InitiatedDate?.ToString("dd/MM/yyyy")
                            </td>

                            <td style="border:1px solid #d9d9d9;">

                                @if (item.VisitedDate != null)
                                {
                                    @item.VisitedDate?.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span>-</span>
                                }

                            </td>

                            <td style="border:1px solid #d9d9d9;">

                                <a asp-action="Delete"
                                   asp-route-id="@item.ID"
                                   onclick="return confirm('Are you sure?')">

                                    <img src="~/images/delete.png"
                                         width="26" />

                                </a>

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>
</table>

</div>

</div>

<script>

    function validatePhoneNumber(input) {

        var error = document.getElementById("phoneNumberError");

        var originalValue = input.value;

        input.value = input.value.replace(/[^0-9]/g, '');

        if (originalValue !== input.value) {

            error.innerHTML = "Only numbers are allowed.";

        } else {

            error.innerHTML = "";
        }
    }
        function validateStudentName(input) {

        var error = document.getElementById("studentNameError");

        var originalValue = input.value;

        // Allow only letters and spaces
        input.value = input.value.replace(/[^A-Za-z\s]/g, '');

        if (originalValue !== input.value) {

            error.innerHTML = "Only letters are allowed.";

        } else {

            error.innerHTML = "";
        }
    }

</script>